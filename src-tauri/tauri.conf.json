{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qx",
  "version": "0.4.7",
  "identifier": "com.mcx.qx",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run prepare:search-tools",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "qx",
        "width": 680,
        "height": 500,
        "minWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/search/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": ["https://api.github.com/repos/mcxen/qx/releases/latest"],
      "pubkey": ""
    }
  }
}
