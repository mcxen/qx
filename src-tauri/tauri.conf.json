{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Qx",
  "version": "0.4.23",
  "identifier": "com.mcx.qx",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run prepare:search-tools",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Qx",
        "width": 680,
        "height": 500,
        "minWidth": 480,
        "minHeight": 360,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/.qx/**",
            "$APPDATA/**",
            "$APPCACHE/**"
          ],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/search/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": ["https://api.github.com/repos/mcxen/qx/releases/latest"],
      "pubkey": ""
    }
  }
}
